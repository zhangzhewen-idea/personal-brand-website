{
  "name": "pbw-web-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev --port 2001",
    "dev:prod": "vite --mode prod --port 3001",
    "build": "npm run build:prod",
    "build:dev": "vue-tsc -b && vite build --mode dev",
    "build:prod": "vue-tsc -b && vite build --mode prod",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "axios": "^1.11.0",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^3.0.3",
    "tailwindcss": "^4.1.12",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.0.5"
  }
}
